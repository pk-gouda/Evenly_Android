<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add expense"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#222222"
            android:paddingBottom="12dp" />

        <!-- Camera button -->
        <ImageButton
            android:id="@+id/btnReceiptImage"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="Add receipt"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_camera"
            app:tint="@color/accent_mint"
            android:layout_marginBottom="16dp" />

        <!-- ITEMIZATION CARD (hidden until scan completes) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardItemization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ITEMIZATION"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:letterSpacing="0.12"
                    android:paddingBottom="10dp" />

                <!-- Column headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Item"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Price"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="6dp" />

                <!-- Dynamic item rows -->
                <LinearLayout
                    android:id="@+id/llItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Divider before totals -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Subtotal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Subtotal"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tvSubtotal"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Tax -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/tvTaxLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tax"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tvTax"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Bold divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp" />

                <!-- Total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#222222" />

                    <TextView
                        android:id="@+id/tvTotal"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Issues warning -->
                <TextView
                    android:id="@+id/tvIssues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"
                    android:padding="8dp"
                    android:background="#FFF3CD"
                    android:textColor="#856404"
                    android:textSize="12sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- Split Receipt Button (shown after scan) -->
        <Button
            android:id="@+id/btnSplitReceipt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Split This Receipt →"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- DEBUG: temporary, remove once parsing is confirmed working -->
        <TextView
            android:id="@+id/tvDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="10sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            android:text="" />

    </LinearLayout>
</ScrollView>